# Twilio Configuration
# Get these values from your Twilio Console (https://console.twilio.com)

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_SERVICE_SID=your_service_sid_here

# Instructions:
# 1. Sign up at https://www.twilio.com
# 2. Go to Console > Account Info to find ACCOUNT_SID and AUTH_TOKEN
# 3. Go to Verify > Services to find SERVICE_SID
# 4. Create a .env file (copy this file) and replace the values
# 5. Keep .env private - never commit it to version control!
